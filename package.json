export type PlaceType =
  | 'city'
  | 'fjord'
  | 'mountain'
  | 'island'
  | 'village'
  | 'landmark'
  | 'nationalpark'
  | 'valley';

export type Region =
  | 'Østlandet'
  | 'Vestlandet'
  | 'Trøndelag'
  | 'Nord-Norge'
  | 'Sørlandet'
  | 'Innlandet'
  | 'Svalbard';

export interface Place {
  id: number;
  name: string;
  lat: number;
  lng: number;
  type: PlaceType;
  region: Region;
  desc: string;
  img: string;
}
