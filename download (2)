#!/usr/bin/env python3
"""Merge only manually reviewed semantic duplicates from the v25 audit."""
import csv, json, pathlib
ROOT = pathlib.Path(__file__).resolve().parents[1]
p = ROOT/'places-data.js'
s = p.read_text()
data = json.loads(s[len('window.PLACES='):-2])
merges = {
    'Langfoss – Etne': 'Langfoss',
    'Geopark Mølen': 'Mølen',
    'Briksdalsbreen (Briksdal glacier)': 'Briksdalsbreen',
}
renames = {
    'Myfallet - Bottom Viewpoint': 'Myfallet – unterer Aussichtspunkt',
    'Myfallet - Top Viewpoint': 'Myfallet – oberer Aussichtspunkt',
}
by_name = {x['name']:x for x in data}
remove = set()
for duplicate, canonical in merges.items():
    if duplicate not in by_name or canonical not in by_name:
        continue
    source, target = by_name[duplicate], by_name[canonical]
    remove.add(duplicate)
    for alias in [source['name'], *source.get('aliases', [])]:
        if alias.casefold() != target['name'].casefold() and alias.casefold() not in {x.casefold() for x in target['aliases']}:
            target['aliases'].append(alias)
    target['mergedRecords'] = target.get('mergedRecords',1) + source.get('mergedRecords',1)
    if source['quality'] > target['quality']:
        target['quality'] = source['quality']
    if not target.get('photo') and source.get('photo'):
        for key in ['photo','photoPage','caption','artist','license','licenseUrl','nearbyPhoto']:
            target[key] = source.get(key,'')
for item in data:
    if item['name'] in renames:
        old = item['name']; item['name'] = renames[old]
        clean_alias = old.replace(' - Bottom Viewpoint',' unterer Aussichtspunkt').replace(' - Top Viewpoint',' oberer Aussichtspunkt')
        if clean_alias.casefold() != item['name'].casefold() and clean_alias not in item['aliases']:
            item['aliases'].append(clean_alias)
data = [x for x in data if x['name'] not in remove]
def trust(score): return 'Gut dokumentiert' if score >= 78 else 'Teilweise geprüft' if score >= 58 else 'Vor Ort prüfen'
for i,item in enumerate(data):
    item['id']=i;item['qualityLabel']=trust(item['quality'])
assert len(data)==1393
assert len({(x['lat'],x['lon']) for x in data})==1393
assert len({x['name'].casefold() for x in data})==1393
p.write_text('window.PLACES='+json.dumps(data,ensure_ascii=False,separators=(',',':'))+';\n')
for old in ROOT.glob('steder_v25_1393.*'): old.unlink()
fields=['id','name','aliases','latitude','longitude','category_id','category_de','group_id','fame_id','region','description','note','access','quality','quality_label','source','research','photo_page','photo_author','photo_license','photo_license_url','merged_records']
rows=[]
for x in data:
    rows.append({'id':x['id'],'name':x['name'],'aliases':' | '.join(x['aliases']),'latitude':x['lat'],'longitude':x['lon'],'category_id':x['categoryId'],'category_de':x['categoryLabel'],'group_id':x['groupId'],'fame_id':x['fameId'],'region':x['region'],'description':x['why'],'note':x['note'],'access':x['access'],'quality':x['quality'],'quality_label':x['qualityLabel'],'source':x['source'],'research':x['research'],'photo_page':x['photoPage'],'photo_author':x['artist'],'photo_license':x['license'],'photo_license_url':x['licenseUrl'],'merged_records':x['mergedRecords']})
with open(ROOT/'steder_v25_1393.csv','w',encoding='utf-8-sig',newline='') as f:
    writer=csv.DictWriter(f,fieldnames=fields);writer.writeheader();writer.writerows(rows)
features=[{'type':'Feature','geometry':{'type':'Point','coordinates':[r['longitude'],r['latitude']]},'properties':{k:v for k,v in r.items() if k not in ('latitude','longitude')}} for r in rows]
(ROOT/'steder_v25_1393.geojson').write_text(json.dumps({'type':'FeatureCollection','name':'Steder i Norge – bereinigte öffentliche Datenbank','license':'ODbL-1.0','attribution':'Contains information from OpenStreetMap, available under ODbL 1.0','features':features},ensure_ascii=False,separators=(',',':')))
print('targeted duplicate merge complete:',len(data))
